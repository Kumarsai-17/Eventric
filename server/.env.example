# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# MongoDB
MONGO_URI=mongodb://localhost:27017/eventric
# Or use MONGODB_URI for production (both work)
MONGODB_URI=mongodb://localhost:27017/eventric

# JWT
JWT_SECRET=425d4c96aafb3a6a85d7e0e75b047a8eee62cecbf3acc111afaab06088efe9523aba4dc7cc19002a92ca95936ee677606bd231974f565a2c8aa7362d875efa95
JWT_EXPIRES_IN=7d

# Payment Gateway
# Set to "true" to use mock payment (no Razorpay needed)
# Set to "false" to use real Razorpay
USE_MOCK_PAYMENT=true

# Razorpay (Only required if USE_MOCK_PAYMENT=false)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Seat lock TTL (seconds)
SEAT_LOCK_TTL=300
